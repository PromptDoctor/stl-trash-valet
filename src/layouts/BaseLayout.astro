---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "STL Trash Valet — Doorstep Trash Collection for STL Metro Apartment Complexes",
  description = "Doorstep trash valet service for apartment complexes across the St. Louis Metro. Generate extra revenue per door with zero extra work. Local, insured, owner-operated.",
  canonical = "https://www.stltrashvalet.com/",
} = Astro.props;

const ogImage = "https://www.stltrashvalet.com/assets/og-image.jpg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Indexing -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Open Graph (Facebook, LinkedIn, iMessage previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="STL Trash Valet — Doorstep trash collection for St. Louis apartment communities" />
    <meta property="og:site_name" content="STL Trash Valet" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Local Business Schema (JSON-LD) — PRIMARY GEO SIGNAL -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "STL Trash Valet",
      "description": "Doorstep trash valet service for apartment complexes across the St. Louis Metro Area. Owner-operated, locally answered, insured.",
      "url": "https://www.stltrashvalet.com",
      "telephone": "+13147232893",
      "email": "sales@stltrashvalet.com",
      "foundingDate": "2025",
      "priceRange": "$$",
      "image": "https://www.stltrashvalet.com/assets/logo.png",
      "logo": "https://www.stltrashvalet.com/assets/logo.png",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "St. Louis",
        "addressRegion": "MO",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "38.6270",
        "longitude": "-90.1994"
      },
      "areaServed": [
        { "@type": "City", "name": "St. Louis", "sameAs": "https://www.wikidata.org/wiki/Q38022" },
        { "@type": "City", "name": "Clayton, Missouri" },
        { "@type": "City", "name": "Chesterfield, Missouri" },
        { "@type": "City", "name": "Florissant, Missouri" },
        { "@type": "City", "name": "O'Fallon, Missouri" },
        { "@type": "City", "name": "St. Charles, Missouri" },
        { "@type": "City", "name": "Belleville, Illinois" },
        { "@type": "City", "name": "O'Fallon, Illinois" },
        { "@type": "City", "name": "Fairview Heights, Illinois" },
        { "@type": "City", "name": "Edwardsville, Illinois" },
        { "@type": "City", "name": "Swansea, Illinois" },
        { "@type": "City", "name": "Collinsville, Illinois" }
      ],
      "serviceType": [
        "Valet Trash Service",
        "Doorstep Trash Collection",
        "Apartment Amenity Service",
        "Residential Waste Collection"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Valet Trash Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Doorstep Valet Trash Collection",
              "description": "Five nights per week doorstep trash pickup for apartment communities. Residents set bags outside their door; we walk it to your dumpster."
            }
          }
        ]
      },
      "sameAs": [
        "https://www.google.com/maps"
      ]
    }
    </script>

    <!-- FAQ Schema (boosts FAQ rich results in Google) -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does valet trash cost the property?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nothing. Our model bills residents directly through your existing rent ledger as a mandatory amenity. The property keeps a margin per unit per month. Zero capital expense, zero labor cost."
          }
        },
        {
          "@type": "Question",
          "name": "What nights and times do you pick up trash?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sunday through Thursday, between 8 PM and midnight. Residents set bagged trash outside their door no earlier than 6 PM. We can customize the schedule for properties with quiet-hours policies."
          }
        },
        {
          "@type": "Question",
          "name": "Are you insured and bonded?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. $1M general liability, workers' comp, and commercial auto on every vehicle. We'll add your property as a named party on our policy at no cost. Certificates of insurance provided within 24 hours."
          }
        },
        {
          "@type": "Question",
          "name": "How long is the valet trash contract?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Standard agreements are 12 months with auto-renewal and a 60-day out clause if performance falls short of agreed service standards."
          }
        },
        {
          "@type": "Question",
          "name": "Do you serve the Illinois side of St. Louis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes — Belleville, O'Fallon, Edwardsville, Fairview Heights, Collinsville, Columbia, Granite City, Swansea, and surrounding Metro East communities. We're a true bi-state operator."
          }
        }
      ]
    }
    </script>

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/logo-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/logo-192.png" />
    <link rel="apple-touch-icon" href="/assets/logo-192.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Manrope:wght@400;500;600;700;800&family=Allura&display=swap" />

    <!-- Theme color (mobile browser chrome) -->
    <meta name="theme-color" content="#1d4a2e" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ==========  TOKENS  ========== */
  :root {
    --ink:        #14201a;
    --ink-soft:   #3a4a40;
    --muted:      #6b7a70;
    --hairline:   #d9d2bf;
    --hairline-2: #e8e1cd;

    --green:      #1d4a2e;
    --green-dark: #0f2e1c;
    --green-deep: #0a2114;
    --green-mid:  #2d6a44;
    --green-soft: #eaf0e9;

    --paper:      #faf7ee;
    --paper-2:    #f5efdf;
    --paper-3:    #ebe2cc;
    --cream-ink:  #f6f0df;

    --gold:       #b8893a;
    --gold-soft:  #e9d8a6;

    --radius:     2px;
    --radius-md:  6px;

    --shadow-sm:  0 1px 2px rgba(20,32,26,.06);
    --shadow-md:  0 10px 30px -12px rgba(20,32,26,.18);
    --shadow-lg:  0 24px 60px -20px rgba(20,32,26,.25);

    --maxw:       1240px;
    --pad:        clamp(20px, 4vw, 56px);

    --serif:  'DM Serif Display', 'Iowan Old Style', Georgia, serif;
    --sans:   'Manrope', system-ui, -apple-system, sans-serif;
    --script: 'Allura', 'Snell Roundhand', cursive;
  }

  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    margin: 0; font-family: var(--sans); color: var(--ink);
    background: var(--paper);
    font-size: 17px; line-height: 1.6; font-weight: 450;
    -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
  }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; border: 0; background: none; color: inherit; }
  input, textarea, select { font: inherit; color: inherit; }
  h1, h2, h3, h4 { margin: 0; font-family: var(--serif); font-weight: 400; letter-spacing: -0.01em; line-height: 1.1; }
  p { margin: 0; }
  ::selection { background: var(--green); color: var(--paper); }

  .container { max-width: var(--maxw); margin: 0 auto; padding-inline: var(--pad); }
  .eyebrow {
    font-family: var(--sans); font-weight: 700; font-size: 12px; letter-spacing: .18em;
    text-transform: uppercase; color: var(--green); display: inline-flex; align-items: center; gap: 10px;
  }
  .eyebrow::before { content: ""; width: 28px; height: 1px; background: currentColor; display: inline-block; }
  .script { font-family: var(--script); font-weight: 400; }

  /* ==========  NAV  ========== */
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(250,247,238,.86);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color .25s ease, background .25s ease;
  }
  .nav.scrolled { border-bottom-color: var(--hairline-2); }
  .nav__inner { display: flex; align-items: center; gap: 32px; height: 78px; }
  .brand { display: flex; align-items: center; gap: 12px; }
  .brand__mark { width: 44px; height: 44px; border-radius: 50%; }
  .brand__name {
    font-family: var(--serif); font-size: 20px; color: var(--green-dark);
    line-height: 1; letter-spacing: .01em;
  }
  .brand__name small {
    display: block; font-family: var(--sans); font-size: 9.5px; letter-spacing: .24em;
    color: var(--muted); font-weight: 600; text-transform: uppercase; margin-top: 4px;
  }
  .nav__links { display: flex; gap: 30px; margin-left: auto; }
  .nav__links a {
    font-size: 14px; font-weight: 600; color: var(--ink-soft);
    padding: 8px 0; position: relative; transition: color .2s ease;
  }
  .nav__links a:hover { color: var(--green); }
  .nav__cta {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--paper); color: var(--green-deep);
    border: 1px solid var(--hairline);
    padding: 11px 20px; border-radius: 999px; font-weight: 700; font-size: 14px;
    transition: background .2s ease, transform .2s ease, border-color .2s ease, color .2s ease;
  }
  .nav__cta:hover { background: var(--paper-2); border-color: var(--green); color: var(--green); transform: translateY(-1px); }
  .nav__cta svg { width: 14px; height: 14px; }
  @media (max-width: 820px) { .nav__links { display: none; } }

  /* ==========  HERO  ========== */
  .hero {
    position: relative; overflow: hidden;
    padding: 80px 0 110px;
    background:
      radial-gradient(1200px 600px at 88% -10%, rgba(29,74,46,.06), transparent 60%),
      radial-gradient(900px 500px at -10% 120%, rgba(184,137,58,.06), transparent 60%),
      var(--paper);
  }
  .hero__grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 64px; align-items: center; }
  .hero__kicker { margin-bottom: 22px; }
  .hero h1 { font-size: clamp(44px, 6vw, 80px); color: var(--green-deep); margin-bottom: 24px; }
  .hero h1 em { font-style: italic; font-family: var(--serif); color: var(--green); }
  .hero h1 .scr {
    font-family: var(--script); font-style: normal; font-weight: 400;
    color: var(--green); font-size: 1.08em; line-height: .5;
    display: inline-block; transform: translateY(.08em);
  }
  .hero__lede { font-size: 19px; color: var(--ink-soft); max-width: 560px; margin-bottom: 36px; }
  .hero__ctas { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    font-weight: 700; font-size: 15px;
    padding: 16px 26px; border-radius: 999px;
    transition: transform .2s ease, background .2s ease, color .2s ease, border-color .2s ease;
    border: 1px solid transparent;
  }
  .btn--primary { background: var(--green); color: var(--paper-2); }
  .btn--primary:hover { background: var(--green-dark); transform: translateY(-1px); }
  .btn--ghost { background: transparent; color: var(--green-deep); border-color: var(--hairline); }
  .btn--ghost:hover { background: var(--paper-2); border-color: var(--green); }
  .btn svg { width: 16px; height: 16px; }
  .hero__trust { display: flex; align-items: center; gap: 18px; margin-top: 40px; font-size: 13px; color: var(--muted); }
  .hero__trust__divider { width: 1px; height: 18px; background: var(--hairline); }

  .hero__visual { position: relative; aspect-ratio: 1/1.05; }
  .hero__badge { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .hero__badge img {
    width: 88%; height: auto;
    filter: drop-shadow(0 30px 60px rgba(15,46,28,.18));
    animation: floaty 6s ease-in-out infinite;
  }
  @keyframes floaty {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50%       { transform: translateY(-10px) rotate(-1deg); }
  }
  .hero__tag {
    position: absolute; background: var(--paper); padding: 14px 18px;
    border-radius: 14px; box-shadow: var(--shadow-md);
    display: flex; align-items: center; gap: 12px;
    border: 1px solid var(--hairline-2);
  }
  .hero__tag .dot { width: 10px; height: 10px; background: var(--green); border-radius: 50%; position: relative; }
  .hero__tag .dot::after {
    content: ""; position: absolute; inset: -6px; border-radius: 50%;
    border: 2px solid var(--green); opacity: .5; animation: pulse 2s ease-out infinite;
  }
  @keyframes pulse {
    0%   { transform: scale(.8); opacity: .6; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  .hero__tag strong { display: block; font-size: 13px; color: var(--ink); }
  .hero__tag span { font-size: 12px; color: var(--muted); }
  .hero__tag--1 { top: 6%; left: -6%; transform: rotate(-3deg); }
  .hero__tag--2 { bottom: 8%; right: -4%; transform: rotate(2deg); }
  .hero__tag--3 { top: 48%; right: -10%; transform: rotate(1deg); }

  @media (max-width: 900px) {
    .hero { padding: 48px 0 72px; }
    .hero__grid { grid-template-columns: 1fr; gap: 36px; }
    .hero__visual { max-width: 420px; margin: 0 auto; }
    .hero__tag--3 { display: none; }
  }

  /* ==========  STATS STRIP  ========== */
  .stats { background: var(--green-deep); color: var(--paper-2); padding: 48px 0; position: relative; overflow: hidden; }
  .stats::before {
    content: ""; position: absolute; inset: 0;
    background-image: repeating-linear-gradient(45deg, rgba(245,239,223,.025) 0 2px, transparent 2px 14px);
    pointer-events: none;
  }
  .stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 48px; position: relative; }
  .stats__item .n { font-family: var(--serif); font-size: 54px; line-height: 1; color: var(--cream-ink); margin-bottom: 8px; letter-spacing: -.02em; }
  .stats__item .l { font-size: 13px; color: rgba(245,239,223,.7); letter-spacing: .06em; }
  @media (max-width: 760px) { .stats__grid { grid-template-columns: repeat(2, 1fr); gap: 32px 24px; } }

  /* ==========  SECTION HEADERS  ========== */
  section { padding: 104px 0; }
  .section-head { max-width: 760px; margin-bottom: 64px; }
  .section-head h2 { font-size: clamp(36px, 4.5vw, 56px); color: var(--green-deep); margin: 14px 0 18px; }
  .section-head h2 .scr { font-family: var(--script); color: var(--green); font-size: 1.08em; display: inline-block; transform: translateY(.06em); }
  .section-head p { color: var(--ink-soft); font-size: 18px; max-width: 600px; }

  /* ==========  PILLARS  ========== */
  .pillars { background: var(--paper-2); }
  .pillars__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .pillar {
    background: var(--paper); border: 1px solid var(--hairline-2);
    padding: 36px 32px 32px; border-radius: var(--radius-md);
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    position: relative; overflow: hidden;
  }
  .pillar:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--green-mid); }
  .pillar__num { font-family: var(--serif); font-size: 13px; color: var(--green); letter-spacing: .18em; }
  .pillar h3 { font-size: 30px; color: var(--green-deep); margin: 14px 0 14px; }
  .pillar p { color: var(--ink-soft); font-size: 15.5px; }
  .pillar__icon {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--green-soft); color: var(--green);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
  }
  .pillar__icon svg { width: 22px; height: 22px; }
  @media (max-width: 880px) { .pillars__grid { grid-template-columns: 1fr; } }

  /* ==========  HOW IT WORKS  ========== */
  .how { background: var(--paper); border-top: 1px solid var(--hairline-2); border-bottom: 1px solid var(--hairline-2); }
  .how__steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; }
  .step { padding: 32px 28px 32px 0; position: relative; }
  .step:not(:last-child)::after {
    content: ""; position: absolute; right: 24px; top: 48px; bottom: 0;
    width: 1px; background: var(--hairline-2);
  }
  .step__n { font-family: var(--serif); font-size: 48px; line-height: 1; color: var(--green); margin-bottom: 18px; }
  .step__n .sub { font-family: var(--sans); font-size: 12px; color: var(--muted); letter-spacing: .18em; font-weight: 700; margin-left: 6px; }
  .step h3 { font-size: 22px; color: var(--green-deep); margin-bottom: 8px; }
  .step p { color: var(--ink-soft); font-size: 15px; }
  @media (max-width: 880px) {
    .how__steps { grid-template-columns: 1fr 1fr; }
    .step:not(:last-child)::after { display: none; }
  }
  @media (max-width: 500px) { .how__steps { grid-template-columns: 1fr; } }

  /* ==========  REVENUE CALCULATOR  ========== */
  .revenue {
    background: linear-gradient(180deg, var(--green-deep) 0%, #0a1c12 100%);
    color: var(--paper-2); position: relative; overflow: hidden;
  }
  .revenue::before {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(700px 300px at 80% 110%, rgba(184,137,58,.10), transparent 70%),
      radial-gradient(500px 400px at -10% -10%, rgba(45,106,68,.18), transparent 70%);
    pointer-events: none;
  }
  .revenue__grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 80px; align-items: center; position: relative; }
  .revenue h2 { font-size: clamp(36px, 4.5vw, 54px); color: var(--cream-ink); margin-bottom: 24px; }
  .revenue h2 .scr { font-family: var(--script); color: var(--gold-soft); font-size: 1.1em; transform: translateY(.06em); display: inline-block; }
  .revenue p { color: rgba(245,239,223,.72); font-size: 17px; margin-bottom: 28px; max-width: 520px; }
  .revenue__list { list-style: none; padding: 0; margin: 0; }
  .revenue__list li {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 0; border-top: 1px solid rgba(245,239,223,.10);
    font-size: 15.5px; color: rgba(245,239,223,.86);
  }
  .revenue__list li:last-child { border-bottom: 1px solid rgba(245,239,223,.10); }
  .revenue__list .check {
    flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%;
    background: var(--gold); color: var(--green-deep);
    display: flex; align-items: center; justify-content: center; margin-top: 1px;
  }
  .revenue__list .check svg { width: 12px; height: 12px; }

  .calc { background: var(--paper); color: var(--ink); padding: 36px 36px 40px; border-radius: 10px; box-shadow: var(--shadow-lg); border: 1px solid var(--hairline-2); }
  .calc__head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 20px; border-bottom: 1px solid var(--hairline-2); margin-bottom: 24px; }
  .calc__head h3 { font-size: 22px; color: var(--green-deep); }
  .calc__head span { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--green); font-weight: 700; }
  .calc__field { margin-bottom: 22px; }
  .calc__field label {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 13px; color: var(--muted); margin-bottom: 10px; font-weight: 600;
    letter-spacing: .04em; text-transform: uppercase;
  }
  .calc__field label .val { font-family: var(--serif); font-size: 22px; color: var(--green-deep); text-transform: none; letter-spacing: 0; }
  .calc__range { -webkit-appearance: none; appearance: none; width: 100%; height: 6px; background: var(--hairline-2); border-radius: 999px; outline: none; }
  .calc__range::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--green); border: 3px solid var(--paper);
    box-shadow: 0 0 0 1px var(--green); cursor: grab;
  }
  .calc__range::-moz-range-thumb {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--green); border: 3px solid var(--paper);
    box-shadow: 0 0 0 1px var(--green); cursor: grab;
  }
  .calc__result {
    background: var(--paper-2); border-radius: 8px; padding: 22px 24px; margin-top: 8px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    border: 1px dashed var(--green-mid);
  }
  .calc__result .lbl { font-size: 13px; color: var(--muted); letter-spacing: .04em; text-transform: uppercase; font-weight: 600; }
  .calc__result .lbl small { display: block; text-transform: none; letter-spacing: 0; font-weight: 400; color: var(--ink-soft); margin-top: 4px; }
  .calc__result .amt { font-family: var(--serif); font-size: 42px; color: var(--green-deep); line-height: 1; }
  .calc__result .amt small { font-size: 14px; color: var(--muted); font-family: var(--sans); font-weight: 600; }
  .calc__foot { margin-top: 18px; font-size: 12px; color: var(--muted); text-align: center; }
  @media (max-width: 980px) { .revenue__grid { grid-template-columns: 1fr; gap: 48px; } }

  /* ==========  SERVICE AREA  ========== */
